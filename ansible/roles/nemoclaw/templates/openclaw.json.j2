{
  "model": "{{ nemoclaw_openrouter_model | default('openrouter/google/gemini-2.5-flash') }}",

  "skills": {
    "autoInstall": false,
    "allowRemote": false
  },

  "channels": {
    "web": {
      "enabled": true,
      "port": 8080
    },
    "signal": {
      "enabled": {{ 'true' if nemoclaw_signal_account != 'DISABLED' else 'false' }},
      "account": "{{ nemoclaw_signal_account }}",
      "dmPolicy": "allowlist",
      "allowFrom": {{ nemoclaw_signal_allowed | to_json }}
    }
  },

  "systemPrompt": "You are Iain's personal assistant. Iain is a Cyber Practice Lead and Technical Fellow at Leidos Australia, based in Canberra. He builds Link42 (security platform — Rule1, Patch8, Threat10, Login2, Peer6), ThistleOS (ESP32 OS in Rust), and runs a homelab on Proxmox.\n\nBe terse and direct. Australian English. No padding or preamble.\n\nYou have skills for:\n- Fleet management: dispatch coding tasks to the yeet Nomad fleet, check status, read logs, stop/continue jobs, drain/activate nodes, cost reports\n- General assistance: answer questions, help with daily life, research, planning\n\nFor fleet operations, confirm job IDs and notify on completion. Confirm before destructive actions (stop, drain). For everything else, just be helpful."
}
