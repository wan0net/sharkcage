{
  "name": "sharkcage",
  "version": "1.0.1",
  "description": "Per-tool kernel sandboxing for OpenClaw — every AI command runs through srt with approve-once capability enforcement",
  "type": "module",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/wan0net/sharkcage.git"
  },
  "homepage": "https://github.com/wan0net/sharkcage",
  "keywords": [
    "openclaw",
    "sandbox",
    "security",
    "srt",
    "bubblewrap",
    "asrt",
    "ai-agent",
    "kernel-sandbox",
    "capability-model"
  ],
  "bin": {
    "sc": "dist/cli/main.js"
  },
  "files": [
    "dist/sharkcage/",
    "dist/supervisor/",
    "bin/",
    "src/",
    "bootstrap.sh",
    "install.sh",
    "policies/",
    "tsconfig.plugin.json",
    "README.md",
    "INSTALL.md"
  ],
  "scripts": {
    "dev": "npx tsx src/cli/main.ts",
    "build": "bash bootstrap.sh",
    "check": "tsc --noEmit",
    "supervisor": "npx tsx src/supervisor/main.ts",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@pondwader/socks5-server": "^1.0.10",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
