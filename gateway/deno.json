{
  "tasks": {
    "dev": "deno run --watch -P=gateway src/index.ts",
    "start": "deno run -P=gateway src/index.ts"
  },
  "permissions": {
    "gateway": {
      "read": ["./data", "./SYSTEM.md", "./src"],
      "write": ["./data"],
      "net": true,
      "env": true,
      "run": false,
      "ffi": false,
      "sys": false
    }
  },
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@0.12"
  },
  "compilerOptions": {
    "strict": true
  }
}
